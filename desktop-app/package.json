{
  "name": "mooddownload-desktop-app",
  "version": "0.0.1",
  "private": true,
  "description": "MoodDownload 桌面端前端工程",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-desktop.mjs",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "electron .",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
